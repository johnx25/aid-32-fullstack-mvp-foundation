DATABASE_URL="postgresql://USER:PASSWORD@PROJECT_REF.supabase.co:5432/postgres?schema=public"
# Required for Prisma migrate commands (use a direct PostgreSQL URL, especially with Supabase).
DIRECT_URL="postgresql://USER:PASSWORD@PROJECT_REF.supabase.co:5432/postgres?schema=public"
# Optional seed override (e.g. Supabase pooled URL if direct host is unreachable).
SEED_DATABASE_URL=""

AUTH_TOKEN_SECRET="replace-with-a-long-random-secret"
NODE_ENV="production"
