DATABASE_URL="postgresql://USER:PASSWORD@PROJECT_REF.supabase.co:5432/postgres?schema=public"
# Preferred for Prisma migrate commands (use direct PostgreSQL host for Supabase when reachable).
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?schema=public"
# Optional explicit migration target override (used before fallback to DIRECT_URL/DATABASE_URL).
MIGRATION_URL=""
# Optional seed override (e.g. pooled URL if direct host is not reachable from your network).
SEED_DATABASE_URL=""
# Optional split inputs. If all three are set, scripts/Prisma can derive DATABASE_URL and DIRECT_URL automatically.
SUPABASE_DB_USER=""
SUPABASE_DB_PASSWORD=""
SUPABASE_PROJECT_REF=""

AUTH_TOKEN_SECRET="replace-with-a-long-random-secret"
NODE_ENV="production"
